# HCMN – Environment Configuration Template
# Copy to .env and fill in your API keys

# General
HCMN_DEBUG=false
HCMN_HOST=0.0.0.0
HCMN_PORT=8000

# Module 1 – Camera Feeds
HCMN_DOT_API_KEY=
HCMN_OPENWEATHER_API_KEY=
HCMN_WINDY_API_KEY=

# Module 2 – Satellite/GPS Tracking
HCMN_GOOGLE_MAPS_API_KEY=
HCMN_OPENSKY_USERNAME=
HCMN_OPENSKY_PASSWORD=
HCMN_AIS_API_KEY=
HCMN_NASA_API_KEY=DEMO_KEY
HCMN_CRIME_API_KEY=
HCMN_N2YO_API_KEY=

# Module 2 – ADS-B Telemetry (adsb.fi — no auth required)
HCMN_ADSB_API_BASE_URL=https://opendata.adsb.fi/api/v3
HCMN_ADSB_POLL_INTERVAL_MS=5000
HCMN_ADSB_SEARCH_RADIUS_NM=25

# Module 2 – Historical Replay Backend (ArangoDB)
HCMN_ARANGO_URL=http://localhost:8529
HCMN_ARANGO_DB_NAME=hcmn_ontology
HCMN_ARANGO_USER=root
HCMN_ARANGO_PASS=

# Object Storage for Camera Frames (S3-compatible)
HCMN_S3_BUCKET=hcmn-historical-frames
HCMN_S3_REGION=us-east-1
HCMN_AWS_ACCESS_KEY_ID=
HCMN_AWS_SECRET_ACCESS_KEY=

# Time-Series Configuration
HCMN_DATA_RETENTION_DAYS=30

# Cell Tower Geolocation APIs
HCMN_OPENCELLID_API_KEY=
HCMN_WIGLE_API_KEY=

# Module 3 – Wi-Fi CSI
HCMN_CSI_ENABLED=false
HCMN_ROUTER_IP=192.168.1.1
HCMN_ROUTER_ADMIN_USER=admin
HCMN_ROUTER_ADMIN_PASSWORD=

# AI Chat
HCMN_OPENAI_API_KEY=
HCMN_OPENAI_MODEL=gpt-4o-mini

# SDR (optional)
HCMN_SDR_ENABLED=false

# CORS
HCMN_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
